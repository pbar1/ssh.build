package(default_visibility = ["//visibility:public"])

config_setting(
    name = "darwin",
    constraint_values = ["@platforms//os:macos"],
)

config_setting(
    name = "linux",
    constraint_values = ["@platforms//os:linux"],
)

cc_library(
    name = "headers",
    hdrs = glob(["include/**/*.h"]),
    includes = ["include"],
)

cc_import(
    name = "libcrypt",
    shared_library = select({
        ":darwin": "lib/libcrypt.dylib",
        ":linux": "lib/libcrypt.so",
    }),
)

cc_library(
    name = "libxcrypt",
    deps = [
        ":headers",
        ":libcrypt",
    ],
)
