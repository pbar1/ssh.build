    "-DHAVE_CONFIG_H",
    "-Ithird_party/libssh2/config",
    "-Ithird_party/libssh2/src/include",
    "-Ithird_party/libssh2/src/src",
]

cxx_library(
    name = "libssh2",
    srcs = _LIBSSH2_SRCS,
    headers = _LIBSSH2_HEADERS,
    exported_preprocessor_flags = [
        "-Ithird_party/libssh2/src/include",
    ],
    deps = [
        "//third_party/nixpkgs:openssl",
        "//third_party/nixpkgs:zlib",
    ],
    preprocessor_flags = _LIBSSH2_PREPROCESSOR_FLAGS,
    visibility = ["PUBLIC"],
)

