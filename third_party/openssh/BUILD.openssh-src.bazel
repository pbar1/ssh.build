load("@ssh_build//third_party/openssh:defs_bazel.bzl", "openssh_binary")
load(
    "@ssh_build//third_party/openssh:defs_shared.bzl",
    "OPENBSD_COMPAT_SRCS",
    "OPENSSH_BINARY_TARGETS",
    "OPENSSH_COMMON_COPTS",
    "OPENSSH_CORE_SRCS",
    "SCP_SRCS",
    "SFTP_SERVER_SRCS",
    "SFTP_SRCS",
    "SSH_ADD_SRCS",
    "SSH_AGENT_SRCS",
    "SSH_KEYGEN_SRCS",
    "SSH_KEYSCAN_SRCS",
    "SSH_KEYSIGN_SRCS",
    "SSH_PKCS11_HELPER_SRCS",
    "SSH_SK_HELPER_SRCS",
    "SSH_SRCS",
    "SSHD_AUTH_SRCS",
    "SSHD_SESSION_SRCS",
    "SSHD_SRCS",
)

package(default_visibility = ["//visibility:public"])

exports_files(["configure"])

_OPENSSH_HEADERS = glob([
    "*.h",
    "openbsd-compat/*.h",
]) + ["@ssh_build//third_party/openssh:openssh_config_hdrs"]

cc_library(
    name = "openbsd_compat",
    srcs = OPENBSD_COMPAT_SRCS,
    hdrs = _OPENSSH_HEADERS,
    copts = OPENSSH_COMMON_COPTS,
    includes = [
        ".",
        "openbsd-compat",
    ],
    deps = [
        "@nix_libxcrypt//:headers",
        "@nix_openssl//:headers",
        "@ssh_build//third_party/nix:darwin_libresolv",
        "@ssh_build//third_party/openssh:openssh_config",
    ],
)

cc_library(
    name = "openssh_core",
    srcs = OPENSSH_CORE_SRCS,
    hdrs = _OPENSSH_HEADERS,
    textual_hdrs = ["umac.c"],
    copts = OPENSSH_COMMON_COPTS,
    includes = [
        ".",
        "openbsd-compat",
    ],
    deps = [
        ":openbsd_compat",
        "@nix_libxcrypt//:libxcrypt",
        "@nix_openssl//:openssl",
        "@nix_zlib//:zlib",
        "@ssh_build//third_party/nix:darwin_libresolv",
        "@ssh_build//third_party/openssh:openssh_config",
    ],
)

openssh_binary(
    name = "scp",
    srcs = SCP_SRCS,
    copts = OPENSSH_COMMON_COPTS,
    deps = [":openssh_core"],
)

openssh_binary(
    name = "sftp",
    srcs = SFTP_SRCS,
    copts = OPENSSH_COMMON_COPTS,
    deps = [":openssh_core"],
)

openssh_binary(
    name = "sftp-server",
    srcs = SFTP_SERVER_SRCS,
    copts = OPENSSH_COMMON_COPTS,
    deps = [":openssh_core"],
)

openssh_binary(
    name = "ssh",
    srcs = SSH_SRCS,
    copts = OPENSSH_COMMON_COPTS,
    deps = [":openssh_core"],
)

openssh_binary(
    name = "ssh-add",
    srcs = SSH_ADD_SRCS,
    copts = OPENSSH_COMMON_COPTS,
    deps = [":openssh_core"],
)

openssh_binary(
    name = "ssh-agent",
    srcs = SSH_AGENT_SRCS,
    copts = OPENSSH_COMMON_COPTS,
    deps = [":openssh_core"],
)

openssh_binary(
    name = "ssh-keygen",
    srcs = SSH_KEYGEN_SRCS,
    copts = OPENSSH_COMMON_COPTS,
    deps = [":openssh_core"],
)

openssh_binary(
    name = "ssh-keyscan",
    srcs = SSH_KEYSCAN_SRCS,
    copts = OPENSSH_COMMON_COPTS,
    deps = [":openssh_core"],
)

openssh_binary(
    name = "ssh-keysign",
    srcs = SSH_KEYSIGN_SRCS,
    copts = OPENSSH_COMMON_COPTS,
    deps = [":openssh_core"],
)

openssh_binary(
    name = "ssh-pkcs11-helper",
    srcs = SSH_PKCS11_HELPER_SRCS,
    copts = OPENSSH_COMMON_COPTS,
    deps = [":openssh_core"],
)

openssh_binary(
    name = "ssh-sk-helper",
    srcs = SSH_SK_HELPER_SRCS,
    copts = OPENSSH_COMMON_COPTS,
    deps = [":openssh_core"],
)

openssh_binary(
    name = "sshd",
    srcs = SSHD_SRCS,
    copts = OPENSSH_COMMON_COPTS,
    deps = [":openssh_core"],
)

openssh_binary(
    name = "sshd-auth",
    srcs = SSHD_AUTH_SRCS,
    copts = OPENSSH_COMMON_COPTS,
    deps = [":openssh_core"],
)

openssh_binary(
    name = "sshd-session",
    srcs = SSHD_SESSION_SRCS,
    copts = OPENSSH_COMMON_COPTS,
    deps = [":openssh_core"],
)

filegroup(
    name = "openssh",
    srcs = [":" + target for target in OPENSSH_BINARY_TARGETS],
)

filegroup(
    name = "all_srcs",
    srcs = glob(["**"]),
)
