 		return SSH_ERR_INVALID_ARGUMENT;
 	switch (mac->type) {
@@ -167,6 +175,8 @@ mac_compute(struct sshmac *mac, uint32_t seqno,
 	if (mac->mac_len > sizeof(u))
 		return SSH_ERR_INTERNAL_ERROR;
 
+	if (mac->type == SSH_NONE)
+		return 0;
 	switch (mac->type) {
 	case SSH_DIGEST:
 		put_u32(b, seqno);
@@ -207,7 +217,9 @@ mac_check(struct sshmac *mac, uint32_t seqno,
