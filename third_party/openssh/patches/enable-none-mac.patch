 		return SSH_ERR_INVALID_ARGUMENT;
+	if (mac->type == SSH_NONE)
+		return 0;
 	if ((r = mac_compute(mac, seqno, data, dlen,
 	    ourmac, sizeof(ourmac))) != 0)
 		return r;
