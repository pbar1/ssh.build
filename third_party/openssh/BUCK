load(
    ":defs_buck.bzl",
    "OPENSSH_COMPILER_FLAGS",
    "OPENSSH_LINKER_FLAGS",
    "OPENSSH_PREPROCESSOR_FLAGS",
    "openssh_binary",
    "openssh_srcs",
)
load(
    ":defs_shared.bzl",
    "OPENBSD_COMPAT_SRCS",
    "OPENSSH_BINARY_TARGETS",
    "OPENSSH_CORE_SRCS",
    "SCP_SRCS",
    "SFTP_SERVER_SRCS",
    "SFTP_SRCS",
    "SSH_ADD_SRCS",
    "SSH_AGENT_SRCS",
    "SSH_KEYGEN_SRCS",
    "SSH_KEYSCAN_SRCS",
    "SSH_KEYSIGN_SRCS",
    "SSH_PKCS11_HELPER_SRCS",
    "SSH_SK_HELPER_SRCS",
    "SSH_SRCS",
    "SSHD_AUTH_SRCS",
    "SSHD_SESSION_SRCS",
    "SSHD_SRCS",
)

_NIXPKGS_DEPS = [
    "//third_party/nixpkgs:darwin_libresolv",
    "//third_party/nixpkgs:libxcrypt",
    "//third_party/nixpkgs:openssl",
    "//third_party/nixpkgs:zlib",
]

_OPENSSH_HEADERS = glob([
    "config/darwin/**/*.h",
    "src/*.h",
    "src/openbsd-compat/*.h",
]) + [
    "src/umac.c",
]

cxx_library(
    name = "openbsd_compat",
    srcs = openssh_srcs(OPENBSD_COMPAT_SRCS),
    compiler_flags = OPENSSH_COMPILER_FLAGS,
    deps = _NIXPKGS_DEPS,
    exported_preprocessor_flags = OPENSSH_PREPROCESSOR_FLAGS,
    headers = _OPENSSH_HEADERS,
    preferred_linkage = "static",
    preprocessor_flags = OPENSSH_PREPROCESSOR_FLAGS,
    visibility = ["PUBLIC"],
)

cxx_library(
    name = "openssh_core",
    srcs = openssh_srcs(OPENSSH_CORE_SRCS),
    compiler_flags = OPENSSH_COMPILER_FLAGS,
    deps = [":openbsd_compat"] + _NIXPKGS_DEPS,
    exported_deps = _NIXPKGS_DEPS,
    exported_linker_flags = OPENSSH_LINKER_FLAGS,
    exported_preprocessor_flags = OPENSSH_PREPROCESSOR_FLAGS,
    headers = _OPENSSH_HEADERS,
    linker_flags = OPENSSH_LINKER_FLAGS,
    preferred_linkage = "static",
    preprocessor_flags = OPENSSH_PREPROCESSOR_FLAGS,
    visibility = ["PUBLIC"],
)

openssh_binary(
    name = "scp",
    srcs = SCP_SRCS,
)

openssh_binary(
    name = "sftp",
    srcs = SFTP_SRCS,
)

openssh_binary(
    name = "sftp-server",
    srcs = SFTP_SERVER_SRCS,
)

openssh_binary(
    name = "ssh",
    srcs = SSH_SRCS,
)

openssh_binary(
    name = "ssh-add",
    srcs = SSH_ADD_SRCS,
)

openssh_binary(
    name = "ssh-agent",
    srcs = SSH_AGENT_SRCS,
)

openssh_binary(
    name = "ssh-keygen",
    srcs = SSH_KEYGEN_SRCS,
)

openssh_binary(
    name = "ssh-keyscan",
    srcs = SSH_KEYSCAN_SRCS,
)

openssh_binary(
    name = "ssh-keysign",
    srcs = SSH_KEYSIGN_SRCS,
)

openssh_binary(
    name = "ssh-pkcs11-helper",
    srcs = SSH_PKCS11_HELPER_SRCS,
)

openssh_binary(
    name = "ssh-sk-helper",
    srcs = SSH_SK_HELPER_SRCS,
)

openssh_binary(
    name = "sshd",
    srcs = SSHD_SRCS,
)

openssh_binary(
    name = "sshd-auth",
    srcs = SSHD_AUTH_SRCS,
)

openssh_binary(
    name = "sshd-session",
    srcs = SSHD_SESSION_SRCS,
)

filegroup(
    name = "openssh",
    srcs = [":" + target for target in OPENSSH_BINARY_TARGETS],
    visibility = ["PUBLIC"],
)
